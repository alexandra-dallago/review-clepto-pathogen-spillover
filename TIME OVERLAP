# ============================================================
#  3. FUNZIONE CAMPANA GAUSSIANA
#     Fitta una gaussiana sui valori mese × taxa
#     e restituisce una curva smooth su griglia fine
# ============================================================

fit_gaussian_curve <- function(data_taxa, taxa_name, n_points = 500) {

  d <- data_taxa %>% filter(Taxa == taxa_name)
  if (nrow(d) < 3) return(NULL)

  # Usa i valori osservati come pesi per stimare mu e sigma
  total  <- sum(d$value)
  mu     <- sum(d$Month * d$value) / total
  sigma  <- sqrt(sum(d$value * (d$Month - mu)^2) / total)
  if (sigma < 0.3) sigma <- 0.3   # evita campane troppo strette
  peak   <- max(d$value)

  # Griglia fine per la curva
  x_seq <- seq(1, 12, length.out = n_points)
  y_seq <- peak * exp(-0.5 * ((x_seq - mu) / sigma)^2)

  tibble(Month_cont = x_seq, value_fit = y_seq, Taxa = taxa_name)
}

# ============================================================
#  4. FUNZIONE PLOT A CAMPANE
# ============================================================

col_clepto  <- "#D62828"
col_wild    <- "#006494"
col_overlap <- "#FFA500"

plot_campane <- function(metrica_data, titolo, y_label, subtitle_txt) {

  # Curve gaussiane per ciascun taxon
  curve_c <- fit_gaussian_curve(metrica_data, "Cleptoparasite")
  curve_w <- fit_gaussian_curve(metrica_data, "Wild bee")

  if (is.null(curve_c) || is.null(curve_w)) {
    message("Dati insufficienti per ", titolo)
    return(NULL)
  }

  curves <- bind_rows(curve_c, curve_w)

  # Area di overlap = intersezione tra le due campane
  # Calcola il min delle due curve su griglia comune
  x_seq   <- curve_c$Month_cont
  y_c     <- curve_c$value_fit
  y_w     <- approx(curve_w$Month_cont, curve_w$value_fit, xout = x_seq)$y
  y_w[is.na(y_w)] <- 0
  y_overlap <- pmin(y_c, y_w)

  overlap_df <- tibble(Month_cont = x_seq, y_overlap = y_overlap)

  # Ticks asse X
  x_breaks <- 1:12
  x_labels <- month_labels

  ggplot() +

    # Area overlap (arancione)
    geom_ribbon(data = overlap_df,
                aes(x = Month_cont, ymin = 0, ymax = y_overlap),
                fill = col_overlap, alpha = 0.45) +

    # Campane piene (semi-trasparenti)
    geom_ribbon(data = curves %>% filter(Taxa == "Cleptoparasite"),
                aes(x = Month_cont, ymin = 0, ymax = value_fit),
                fill = col_clepto, alpha = 0.20) +
    geom_ribbon(data = curves %>% filter(Taxa == "Wild bee"),
                aes(x = Month_cont, ymin = 0, ymax = value_fit),
                fill = col_wild, alpha = 0.20) +

    # Contorni campane
    geom_line(data = curves %>% filter(Taxa == "Cleptoparasite"),
              aes(x = Month_cont, y = value_fit),
              color = col_clepto, linewidth = 1.4) +
    geom_line(data = curves %>% filter(Taxa == "Wild bee"),
              aes(x = Month_cont, y = value_fit),
              color = col_wild, linewidth = 1.4) +

    # Punti osservati
    geom_point(data = metrica_data %>% filter(Taxa == "Cleptoparasite"),
               aes(x = Month, y = value),
               color = col_clepto, size = 2.5, shape = 16) +
    geom_point(data = metrica_data %>% filter(Taxa == "Wild bee"),
               aes(x = Month, y = value),
               color = col_wild, size = 2.5, shape = 16) +

    # Etichetta overlap
    annotate("text",
             x     = x_seq[which.max(y_overlap)],
             y     = max(y_overlap) * 1.08,
             label = "Overlap window:\nincreased transmission risk",
             size  = 3.2, color = darken(col_overlap, 0.3),
             fontface = "italic", hjust = 0.5) +

    # Etichette gruppi (come nell'immagine esempio)
    annotate("text",
             x     = curve_c$Month_cont[which.max(curve_c$value_fit)] - 1.5,
             y     = max(curve_c$value_fit) * 0.85,
             label = "Cleptoparasite\nactivity",
             color = col_clepto, size = 3.5, fontface = "bold", hjust = 1) +
    annotate("text",
             x     = curve_w$Month_cont[which.max(curve_w$value_fit)] + 1.5,
             y     = max(curve_w$value_fit) * 0.85,
             label = "Wild Bee\nactivity",
             color = col_wild, size = 3.5, fontface = "bold", hjust = 0) +

    scale_x_continuous(breaks = x_breaks, labels = x_labels,
                       limits = c(1, 12), expand = expansion(mult=0.02)) +
    scale_y_continuous(expand = expansion(mult = c(0, 0.15))) +

    labs(title    = titolo,
         subtitle = subtitle_txt,
         x        = NULL,
         y        = y_label) +

    theme_minimal(base_size = 13) +
    theme(
      plot.title      = element_text(face="bold", size=13, hjust=0.5),
      plot.subtitle   = element_text(size=9, hjust=0.5, color="grey40"),
      axis.title.y    = element_text(size=11),
      axis.text.x     = element_text(size=11),
      panel.grid.minor = element_blank(),
      panel.grid.major.x = element_blank(),
      legend.position = "none"
    )
}

# Helper per scurire un colore (per il testo overlap)
darken <- function(color, factor = 0.3) {
  col <- col2rgb(color) / 255
  col <- col * (1 - factor)
  rgb(col[1], col[2], col[3])
}

